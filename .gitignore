# --- Build Outputs ---
# These are generated by the compiler. No need to save them.
Debug/
Release/
bin/
obj/
*.elf
*.bin
*.hex
*.map
*.list

# --- Dependency Files ---
# These are generated during compilation to track header changes.
*.d

# --- IDE Specific ---
# These are temporary files created by CubeIDE for the current session.
.settings/
.mxproject
*.launch
*.history
*.bak

# --- OS Trash ---
Thumbs.db
.DS_Store

.metadata/